# Neon PostgreSQL — obtenelo en console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Brevo — obtenelo en app.brevo.com > SMTP & API > API Keys
BREVO_API_KEY=xkeysib-...

# Email desde donde sale la notificación (debe estar verificado en Brevo)
FROM_EMAIL=noreply@adoops.ai

# Email que recibe los leads
NOTIFY_EMAIL=hola@adoops.ai

# =============================================================================
# Demo "Reportes de Terreno" — WhatsApp (WaSender) → IA → dashboard (/terreno)
# =============================================================================

# WaSender — https://wasenderapi.com (API Keys del número conectado)
WASENDER_API_KEY=
# Secreto opcional para verificar la firma del webhook (header x-webhook-signature)
WASENDER_WEBHOOK_SECRET=

# OpenAI — transcripción (Whisper) Y extracción estructurada (function calling)
OPENAI_API_KEY=sk-...
# Modelo de transcripción (opcional)
STT_MODEL=gpt-4o-transcribe
# Modelo de extracción (opcional). Para más calidad: gpt-4o
EXTRACT_MODEL=gpt-4o-mini
